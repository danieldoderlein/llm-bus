# LLM Bus - environment. Copy to .env locally. For a hosted deploy, supply these via your
# platform's secret store (never commit real values).

# PostgreSQL connection string for the dedicated database (own DB + role).
DATABASE_URL=postgres://llm_bus:CHANGEME@127.0.0.1:5432/llm_bus

# Port the service listens on. Bind locally; expose via a reverse proxy / platform load balancer.
PORT=8787

# Public URL the service is served at (used for logging / health output only).
PUBLIC_URL=https://example.com

# Comma-separated Host allow-list for MCP DNS-rebinding protection.
# Set in production (the public host). Leave unset in dev/test (ephemeral ports).
ALLOWED_HOSTS=example.com

NODE_ENV=production

# --- Billing (decision 015), all optional. Billing is INERT unless STRIPE_SECRET_KEY is set. ---
# Stripe keys (TEST mode for dev). Never commit real values - use the secret store.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Where Checkout/Portal return to (the dashboard host); defaults to PUBLIC_URL/admin.
# STRIPE_PORTAL_RETURN_URL=https://app.example.com/admin
# Credit dials (1 token = 1 NOK). Defaults shown.
# TRIAL_GRANT_TOKENS=50
# WELCOME_GRANT_TOKENS=100
# RECHARGE_THRESHOLD=10
# RECHARGE_MAX_FAILURES=3
